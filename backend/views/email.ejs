<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>New Recipe on Z-Recipes</title>
</head>
<body style="margin:0;padding:0;background-color:#fef9f0;font-family:'Helvetica Neue',Helvetica,Arial,sans-serif;">

  <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color:#fef9f0;padding:40px 0;">
    <tr>
      <td align="center">

        <table width="600" cellpadding="0" cellspacing="0" border="0" style="max-width:600px;width:100%;background-color:#ffffff;border-radius:16px;overflow:hidden;box-shadow:0 4px 24px rgba(0,0,0,0.08);">

          <tr>
            <td style="background:linear-gradient(135deg,#f59e0b,#f97316);padding:36px 40px;text-align:center;">
              <p style="margin:0;font-size:36px;">🍊</p>
              <h1 style="margin:10px 0 4px;color:#ffffff;font-size:28px;font-weight:800;letter-spacing:-0.5px;">Z-Recipes</h1>
              <p style="margin:0;color:#fef3c7;font-size:14px;">A fresh recipe just landed in the community</p>
            </td>
          </tr>

          <tr>
            <td style="padding:36px 40px;">

              <p style="margin:0 0 24px;color:#374151;font-size:16px;line-height:1.6;">
                Hey there! 👋 <strong style="color:#d97706;"><%= name %></strong> just shared a delicious new recipe with the Z-Recipes community. Go check it out!
              </p>

              <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color:#fffbeb;border:1px solid #fde68a;border-radius:12px;overflow:hidden;margin-bottom:28px;">
                <tr>
                  <td style="padding:24px 28px;">
                    <p style="margin:0 0 6px;font-size:11px;font-weight:700;color:#d97706;text-transform:uppercase;letter-spacing:1px;">New Recipe</p>
                    <h2 style="margin:0 0 14px;color:#1f2937;font-size:22px;font-weight:800;">🍽️ <%= recipe.title %></h2>

                    <% if (recipe.description) { %>
                    <p style="margin:0 0 20px;color:#6b7280;font-size:14px;line-height:1.7;"><%= recipe.description %></p>
                    <% } %>

                    <% if (recipe.ingredients && recipe.ingredients.length > 0) { %>
                    <p style="margin:0 0 10px;font-size:12px;font-weight:700;color:#92400e;text-transform:uppercase;letter-spacing:0.8px;">Ingredients</p>
                    <table cellpadding="0" cellspacing="0" border="0" style="margin-bottom:4px;">
                      <tr>
                        <td>
                          <% recipe.ingredients.forEach(function(ingredient) { %>
                          <span style="display:inline-block;background-color:#fef3c7;color:#92400e;font-size:12px;font-weight:600;padding:4px 12px;border-radius:999px;margin:3px 4px 3px 0;border:1px solid #fde68a;">
                            <%= ingredient %>
                          </span>
                          <% }); %>
                        </td>
                      </tr>
                    </table>
                    <% } %>
                  </td>
                </tr>
              </table>

              <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom:28px;">
                <tr>
                  <td align="center">
                    <a href="#" style="display:inline-block;background:linear-gradient(135deg,#f59e0b,#f97316);color:#ffffff;font-size:15px;font-weight:700;text-decoration:none;padding:14px 36px;border-radius:999px;box-shadow:0 4px 12px rgba(249,115,22,0.35);">
                      Browse All Recipes →
                    </a>
                  </td>
                </tr>
              </table>

              <p style="margin:0;color:#9ca3af;font-size:13px;line-height:1.6;text-align:center;">
                You're receiving this because you're part of the Z-Recipes community.<br/>
                Happy cooking! 🥘
              </p>

            </td>
          </tr>

          <tr>
            <td style="background-color:#f9fafb;border-top:1px solid #f3f4f6;padding:20px 40px;text-align:center;">
              <p style="margin:0;color:#d1d5db;font-size:12px;">© 2026 Z-Recipes &nbsp;·&nbsp; Made with ❤️ for food lovers</p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>

</body>
</html>
